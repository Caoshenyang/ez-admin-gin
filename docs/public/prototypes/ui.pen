              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Q3ciG",
              "name": "p3",
              "fill": "#374151",
              "content": "3. 表格、筛选、分页、权限树、日志状态必须真实可用。",
              "fontFamily": "Inter",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "S5RKl",
              "name": "p4",
              "fill": "#374151",
              "content": "4. 后台系统优先效率和可扫描性，不做营销式页面。",
              "fontFamily": "Inter",
              "fontSize": 15,
              "fontWeight": "normal"
            }
          ]
