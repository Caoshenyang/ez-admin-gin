# EZ Admin Gin 环境变量配置
# 复制此文件为 .env 并修改对应值：cp .env.example .env

# ---- 必须修改 ----

# JWT 签名密钥，生产环境必须替换为随机字符串。
EZ_AUTH_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ---- 数据库 ----

# Docker Compose 部署（后端在容器内）用容器名 postgres；
# 服务器直接部署（后端在宿主机）用 127.0.0.1。
EZ_DATABASE_HOST=postgres
EZ_DATABASE_PORT=5432
EZ_DATABASE_USER=ez_admin
EZ_DATABASE_PASSWORD=ez_admin_123456
EZ_DATABASE_NAME=ez_admin

# ---- Redis ----

# 同上，Docker Compose 用 redis，服务器直接部署用 127.0.0.1。
EZ_REDIS_HOST=redis
EZ_REDIS_PORT=6379
EZ_REDIS_PASSWORD=

# ---- 应用 ----

EZ_APP_ENV=prod
EZ_SERVER_ADDR=:8080
EZ_LOG_LEVEL=info
EZ_LOG_FORMAT=json

# ---- Nginx（Docker Compose 部署时使用）----

EZ_NGINX_PORT=80
EZ_NGINX_CONF=nginx.conf

# ---- Docker Hub（compose.deploy.yml 使用）----

DOCKERHUB_USERNAME=your-dockerhub-username

# ---- SSL（Cloudflare 源站证书）----

EZ_SSL_ENABLED=false
